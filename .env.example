# Quant Strategies — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Vars prefixed with `export` are also sourced in bash scripts (psql, liquibase, extractddl).
# Vars without `export` are only read by Python (python-dotenv / api/main.py).

# ---------------------------------------------------------------------------
# Data Sources
# ---------------------------------------------------------------------------

# Alpha Vantage (free key: https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=your_key_here

# Glassnode (optional — on-chain data)
# GLASSNODE_API_KEY=your_key_here

# Yahoo Finance — no API key needed (uses yfinance library)
# Supported tickers: equities (AAPL), ETFs (SPY), indices (^GSPC), crypto (BTC-USD)

# Futu OpenD gateway (only needed for HK/US equity via Futu)
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# NASDAQ Data Link (free key: https://data.nasdaq.com/account/profile)
NASDAQ_DATA_LINK_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# PostgreSQL — QuantDB (accessed via AWS SSM port-forward on localhost:5433)
# ---------------------------------------------------------------------------

export QUANTDB_HOST=localhost
export QUANTDB_PORT=5433
export QUANTDB_USERNAME=your_db_user
export QUANTDB_PASSWORD=your_db_password

# Optional: override the full psycopg conninfo string (takes precedence over individual vars above)
# export QUANTDB_CONNINFO=host=localhost port=5433 dbname=quantdb user=your_db_user password=your_db_password sslmode=require

# Used directly by psql CLI (avoids interactive password prompt)
export PGPASSWORD="${QUANTDB_PASSWORD}"

# ---------------------------------------------------------------------------
# Liquibase (db/liquidbase/ migrations)
# ---------------------------------------------------------------------------

export LIQUIBASE_COMMAND_URL=jdbc:postgresql://localhost:5433/quantdb
export LIQUIBASE_COMMAND_USERNAME=your_db_user
export LIQUIBASE_COMMAND_PASSWORD=your_db_password

# ---------------------------------------------------------------------------
# FastAPI backend (api/)
# ---------------------------------------------------------------------------

# Comma-separated allowed CORS origins for the FastAPI backend.
# Add your frontend URL here (default covers local Vite dev server).
# CORS_ORIGINS=http://localhost:5173

# Set USE_SSM=1 in CI / production to load secrets from AWS SSM Parameter Store
# instead of this .env file.  All parameters must exist under /quant/<APP_ENV>/.
# USE_SSM=1
# APP_ENV=prod

# AWS region used when USE_SSM=1 (default: ap-southeast-1)
# AWS_REGION=ap-southeast-1

# ---------------------------------------------------------------------------
# Frontend (Vite dev server — frontend/)
# ---------------------------------------------------------------------------

# Backend API base URL proxied by Vite. Default assumes uvicorn on :8000.
# VITE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Authentication (JWT cookie session — see docs/design/login.md §8.3)
# ---------------------------------------------------------------------------

# Symmetric secret for HS256 JWT signing. Generate with:
#   openssl rand -base64 32
# In production (APP_ENV=prod), this MUST be set — the API will refuse to start
# without it.  Store under SSM /quant/prod/JWT_SECRET (never commit).
# In dev mode (default), omitting this is fine — the API auto-generates a random
# secret on each startup (all prior sessions invalidate on restart).
# Rotation: change the value and restart — all existing sessions invalidate.
JWT_SECRET=replace_me_with_openssl_rand_base64_32
