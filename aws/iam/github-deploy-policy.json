{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMRunCommand",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:GetCommandInvocation"
      ],
      "Resource": [
        "arn:aws:ssm:ap-southeast-1::document/AWS-RunShellScript",
        "arn:aws:ec2:ap-southeast-1:539163478329:instance/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Project": "quant"
        }
      }
    },
    {
      "Sid": "SSMRunCommandDocument",
      "Effect": "Allow",
      "Action": "ssm:SendCommand",
      "Resource": "arn:aws:ssm:ap-southeast-1::document/AWS-RunShellScript"
    }
  ]
}
