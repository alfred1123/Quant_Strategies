        <rollback><sql>DROP PROCEDURE IF EXISTS CORE_ADMIN.SP_UPD_APP_USER_BUMP_TOKEN;</sql></rollback>
    </changeSet>

    <!-- ========== Grants (runs LAST, after all schemas/tables/procs exist) ========== -->
    <!-- runOnChange=true so newly added tables/procs in BT/INST/TRADE/REFDATA
         get the right privileges on every deploy. See docs/design/login.md §7.4. -->

    <changeSet id="099-core-admin-grants" author="alfcheun" context="grant" runOnChange="true">
        <sqlFile path="sql/GRANTS.sql" relativeToChangelogFile="true" splitStatements="true" stripComments="true"/>
        <rollback>
            <!-- Atomically revoke every privilege held by the two login users.
                 Roles themselves are NOT dropped — they were provisioned
                 manually outside Liquibase. -->
            <sql>
                DO $$
                BEGIN
                    IF EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'quant_app') THEN
                        EXECUTE 'DROP OWNED BY quant_app CASCADE';
                    END IF;
                    IF EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'quant_admin') THEN
                        EXECUTE 'DROP OWNED BY quant_admin CASCADE';
                    END IF;
                END
                $$;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
