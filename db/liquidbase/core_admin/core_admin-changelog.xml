<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Login users (quant_app, quant_admin) are provisioned manually outside
         Liquibase to keep their passwords off disk. See docs/design/login.md
         §7.3. This changelog only manages their GRANTs. -->

    <!-- ========== CORE_ADMIN tables ========== -->

    <changeSet id="010-core-admin-log-proc-detail" author="alfcheun" context="core_admin" runOnChange="false">
        <sqlFile path="tables/LOG_PROC_DETAIL.sql" relativeToChangelogFile="true" splitStatements="true" stripComments="true"/>
        <rollback><sql>DROP TABLE IF EXISTS CORE_ADMIN.LOG_PROC_DETAIL;</sql></rollback>
    </changeSet>

    <changeSet id="030-core-admin-app-user" author="alfcheun" context="core_admin" runOnChange="false">
        <sqlFile path="tables/APP_USER.sql" relativeToChangelogFile="true" splitStatements="true" stripComments="true"/>
        <rollback><sql>DROP TABLE IF EXISTS CORE_ADMIN.APP_USER;</sql></rollback>
    </changeSet>

